# Wandbox public API endpoint (default works without any setup).
VITE_WANDBOX_URL=https://wandbox.org/api

# Optional: legacy Piston endpoint, only used by src/lib/piston.ts if imported.
# The public emkc.org Piston API is whitelist-only as of 2026-02-15.
VITE_PISTON_URL=http://localhost:2000/api/v2

# OpenAI API key for the AI Assistance pane (FALLBACK provider).
# WARNING: Vite bundles VITE_-prefixed variables into the client. The key is
# visible to anyone who loads the page. Use only for local/personal dev.
# For production, proxy through a backend you control.
VITE_OPENAI_API_KEY=

# --- Azure AI Foundry (PREFERRED provider, uses your own AAD identity) -----
# When you are signed in via `az login` (or any DefaultAzureCredential source
# such as VS Code Azure, Managed Identity, or AZURE_* env vars), the AI panel
# will use Azure AI Foundry instead of OpenAI. No API key needed.
#
# The Vite dev server runs a tiny localhost-only "auth broker" that mints a
# bearer token via @azure/identity's DefaultAzureCredential and serves it to
# the SPA at /auth/token. Tokens never touch disk.
#
# IMPORTANT: the broker is DEV-ONLY. Do not deploy it. For production, replace
# it with a real backend that holds the credential server-side and proxies
# Foundry calls.
VITE_FOUNDRY_ENDPOINT=https://defaultfoundryresource.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
VITE_FOUNDRY_DEPLOYMENT=gpt-5.3-codex

# Set to 1 to disable the broker (e.g., when offline or in CI).
# VITE_DISABLE_FOUNDRY=1
